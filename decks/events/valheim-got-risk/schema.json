{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mhdelta.github.io/got-risk-deck/decks/events/valheim-got-risk/schema.json",
  "title": "Risk Event Deck",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "cards"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional reference to this schema file."
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "name", "language", "version", "createdAt", "houses", "notes"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "language": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "createdAt": { "type": "string" },
        "houses": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "flavor", "ruleText"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^evt-\\d{3}$"
          },
          "title": { "type": "string" },
          "flavor": { "type": "string" },
          "ruleText": { "type": "string" }
        }
      }
    }
  }
}
